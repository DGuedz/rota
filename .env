# ROTA Environment Configuration

# ------------------------------
# API Configuration
# ------------------------------
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ------------------------------
# Database (PostgreSQL via Docker)
# ------------------------------
DATABASE_URL="postgresql://rota_admin:rota_password@localhost:5432/rota_db?schema=public"

# ------------------------------
# Redis
# ------------------------------
REDIS_URL="redis://localhost:6379"

# ------------------------------
# Observability
# ------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_SERVICE_NAME="rota-api"

# ------------------------------
# Stellar / Soroban Config
# ------------------------------
STELLAR_NETWORK="testnet"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
SOROBAN_SECRET_KEY="S..." # Replace with agent testnet secret
