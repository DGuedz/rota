{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ROTA Skill Schema - proof-verifier",
  "description": "Verifies Zero-Knowledge proofs for A2A task completion.",
  "input": {
    "type": "object",
    "properties": {
      "proof": {
        "type": "string"
      },
      "taskId": {
        "type": "string"
      }
    },
    "required": [
      "proof",
      "taskId"
    ]
  },
  "output": {
    "type": "object",
    "properties": {
      "verified": {
        "type": "boolean"
      },
      "score": {
        "type": "number"
      }
    }
  }
}