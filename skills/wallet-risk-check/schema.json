{
  "input": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "wallet-risk-check input",
    "type": "object",
    "required": ["walletAddress"],
    "properties": {
      "walletAddress": {
        "type": "string",
        "minLength": 16,
        "description": "Wallet or account address to analyze"
      },
      "chain": {
        "type": "string",
        "enum": ["stellar", "evm", "solana", "unknown"],
        "default": "unknown"
      },
      "context": {
        "type": "string",
        "maxLength": 280,
        "description": "Optional usage context for the analysis"
      }
    },
    "additionalProperties": false
  },
  "output": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "wallet-risk-check output",
    "type": "object",
    "required": [
      "walletAddress",
      "riskScore",
      "riskLevel",
      "flags",
      "summary",
      "confidence"
    ],
    "properties": {
      "walletAddress": { "type": "string" },
      "riskScore": { "type": "integer", "minimum": 0, "maximum": 100 },
      "riskLevel": {
        "type": "string",
        "enum": ["low", "medium", "high", "critical"]
      },
      "flags": {
        "type": "array",
        "items": { "type": "string" }
      },
      "summary": { "type": "string" },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "signals": {
        "type": "object",
        "additionalProperties": true
      },
      "recommendedAction": {
        "type": "string",
        "enum": ["allow", "review", "block"]
      }
    },
    "additionalProperties": false
  }
}
