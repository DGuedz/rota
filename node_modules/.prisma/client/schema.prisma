generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Modelos Iniciais do ROTA Core
// Este schema foca na Foundation e será expandido nos próximos Milestones.
// ----------------------------------------------------------------------------

model Agent {
  id         String   @id @default(uuid())
  address    String   @unique // Stellar Account Public Key
  name       String?
  reputation Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relações futuras: Intents, RFQs, Bids, Escrows
}

model Skill {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  endpoint    String?
  minBond     Float    @default(0) // Mínimo de garantia onchain necessária
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
